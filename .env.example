# Base de données
DATABASE_URL=postgresql://voltaire:voltaire@db:5432/voltaire_catalog

# JWT
JWT_SECRET=change-me-in-production-use-256-bit-random-key
JWT_EXPIRE_MINUTES=60

# Admin par défaut (créé au démarrage si aucun user en DB)
ADMIN_EMAIL=admin@voltaire.com
ADMIN_PASSWORD=admin

# Environnement
ENVIRONMENT=development
